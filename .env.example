POSTGRES_USER=admin
POSTGRES_PASSWORD=localpsql2025
DATABASE_URL=postgres://admin:localpsql2025@localhost:5432/rustwebdev
DB_POOL_MAX=5

# Bootstrap first admin if none exists (ADMIN_PASSWORD still accepted as fallback)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me

RUST_LOG=handle_errors=warn,web_service=info,warp=error
